# Base URL per GitHub Pages (deve corrispondere al percorso del repository)
# Esempio: VITE_BASE_URL=/medi-trace/
# In sviluppo locale lasciare vuoto oppure /
VITE_BASE_URL=/

# Nessuna altra variabile d'ambiente richiesta.
# L'autenticazione avviene tramite GitHub Personal Access Token inserito dall'utente a runtime.
# Non servono: Google Cloud, client_secret, API key.

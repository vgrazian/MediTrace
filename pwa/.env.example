# Base URL per GitHub Pages (deve corrispondere al percorso del repository)
# Esempio: VITE_BASE_URL=/medi-trace/
# In sviluppo locale lasciare vuoto oppure /
VITE_BASE_URL=/

# Account di test (solo sviluppo locale). Lasciare disattivato in produzione.
# VITE_DEV_SEED_ACCOUNT=1
# VITE_DEV_SEED_USERNAME=prova
# VITE_DEV_SEED_PASSWORD=Prova123!
# VITE_DEV_SEED_GITHUB_TOKEN=github_pat_...

# Account admin di emergenza (legacy fallback senza Supabase).
# Usare solo in ambienti controllati.
# VITE_EMERGENCY_ADMIN_ENABLED=1
# VITE_EMERGENCY_ADMIN_USERNAME=admin_emergenza
# VITE_EMERGENCY_ADMIN_PASSWORD=PasswordSicura123!
# VITE_EMERGENCY_ADMIN_EMAIL=meditace0@gmail.com
# VITE_EMERGENCY_ADMIN_FIRST_NAME=Admin
# VITE_EMERGENCY_ADMIN_LAST_NAME=Emergenza
# VITE_EMERGENCY_ADMIN_GITHUB_TOKEN=github_pat_...

# Supabase Auth + sync backend condiviso (OBBLIGATORIO per multi-device condiviso)
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# VITE_SUPABASE_REDIRECT_TO=http://localhost:5173/#/impostazioni
# In produzione su GitHub Pages, impostare le stesse chiavi nelle GitHub Variables.

# Sync periodico automatico (solo con Supabase configurato)
# L'app sincronizza automaticamente ogni N minuti ma SOLO se ci sono
# modifiche pendenti. Ogni sync carica ~185 KB. Con 15 min e free tier
# Supabase (5 GB/mese), il consumo massimo teorico è ~533 MB/mese (10.7%).
# Minimo: 5 minuti. Default: 15 minuti.
# VITE_SYNC_INTERVAL_MINUTES=15

# Web Push API (E2 notifiche base)
# VITE_VAPID_PUBLIC_KEY=BKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# In produzione su GitHub Pages, impostare anche VITE_VAPID_PUBLIC_KEY nelle GitHub Variables.

# ── Axiom Logging ────────────────────────────────────────────────────────────────
# Logging operazionale GDPR-compliant. Se VITE_AXIOM_TOKEN non è configurato,
# il logger degrada automaticamente a console.warn (nessun invio in rete).
# VITE_AXIOM_TOKEN=xaat-xxx
# VITE_AXIOM_EDGE_URL=https://eu-central-1.aws.edge.axiom.co
# VITE_AXIOM_DATASET=meditrace
# VITE_AXIOM_ENCRYPTION_SALT=<salt-esadecimale>
# VITE_AXIOM_ENCRYPTION_PASSPHRASE=<passphrase-min-16-chars>
# NOTA: La passphrase NON deve mai essere committata in chiaro.
#       Usare GitHub Secrets per CI/CD e variabili d'ambiente locali per sviluppo.

# Email sending via Resend (Supabase Edge Function proxy)
# VITE_PASSWORD_RESET_EMAIL_API=https://kmutczzqnffxxxwdiuip.supabase.co/functions/v1/send-email
# Richiede: supabase functions deploy send-email + supabase secrets set RESEND_API_KEY=re_xxx

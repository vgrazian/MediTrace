{
    "name": "medi-trace",
    "version": "0.3.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "check:palette": "bash ./scripts/check-palette.sh",
        "provision:default-users": "node ./scripts/provision-default-online-users.mjs",
        "test:online-main": "node ./scripts/online-two-user-sync.mjs \"$SITE_URL\"",
        "test:online-performance": "node ./scripts/online-performance-check.mjs \"$SITE_URL\"",
        "test:online-smoke": "bash ./scripts/smoke-pages.sh \"$SITE_URL\"",
        "test:online-chaos": "bash ./scripts/chaos-pages.sh \"$SITE_URL\"",
        "test:unit": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test": "npm run check:palette && npm run test:unit && npm run test:e2e",
        "demo:load": "node scripts/seed-demo.js",
        "demo:reset": "node scripts/reset-clean.js"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.101.1",
        "dexie": "^3.2.7",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.7",
        "papaparse": "^5.5.3",
        "vue": "^3.4.21",
        "vue-router": "^4.3.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@vitejs/plugin-vue": "^5.0.4",
        "@vitest/coverage-v8": "^4.1.2",
        "esbuild": "^0.27.7",
        "vite": "^5.2.8",
        "vite-plugin-pwa": "^0.20.0",
        "vitest": "^4.1.2"
    }
}